<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie consent">
  <div class="cookie-banner-content">
    <div class="cookie-banner-text">
      <p><%= t.cookie_banner.message %></p>
      <a href="/privacy-policy" class="cookie-banner-link"><%= t.cookie_banner.learn_more %></a>
    </div>
    <div class="cookie-banner-actions">
      <button class="cookie-btn cookie-btn-accept" id="acceptCookies"><%= t.cookie_banner.accept %></button>
      <button class="cookie-btn cookie-btn-decline" id="declineCookies"><%= t.cookie_banner.decline %></button>
    </div>
  </div>
</div>

<script>
  (function() {
    var banner = document.getElementById('cookieBanner');
    var acceptBtn = document.getElementById('acceptCookies');
    var declineBtn = document.getElementById('declineCookies');

    if (!banner) return;

    var cookieConsent = document.cookie.split('; ').find(row => row.startsWith('cookie_consent='));
    if (cookieConsent) {
      banner.style.display = 'none';
    }

    acceptBtn.addEventListener('click', function() {
      document.cookie = 'cookie_consent=accepted; max-age=31536000; path=/';
      banner.style.display = 'none';
    });

    declineBtn.addEventListener('click', function() {
      document.cookie = 'cookie_consent=declined; max-age=31536000; path=/';
      banner.style.display = 'none';
    });
  })();
</script>
