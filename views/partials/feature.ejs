<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../../static/styles/main.css">
    <link rel="stylesheet" href="../../static/styles/partials/feature.css" />
    <title>Document</title>
  </head>
  <body>
    <section class="section feature-section">
      <div class="container feature-container">
          <div class="feature-main-heading">
              <h2 class="feature-secondary-heading"><%= t.feature.title %></h2>
              <p><%= t.feature.desc %></p>
          </div>
          <div class="feature-even-column">
              <div class="feature-even-column-left">
                  <div class="feature-features">
                      <img class="feature-img" src="../../static/assets/feature1.webp" alt="Taskify apps available on multiple devices">
            <h3 class="feature-heading"><%= t.feature.feature1_title %></h3>
            <p class="feature-text"><%= t.feature.feature1_desc %></p>
            <a href="#" class="feature-btn feature-btn" aria-label="Download Taskify apps"><%= t.feature.feature1_btn %></a>
                  </div>
                  <div class="feature-features">
                      <img class="feature-img" src="../../static/assets/feature2.webp" alt="Customizable task list with filters and labels">
                      <h3 class="feature-heading"><%= t.feature.feature2_title %></h3>
                      <p class="feature-text"><%= t.feature.feature2_desc %></p>
                      <a href="#" class="feature-btn feature-btn" aria-label="See all Taskify features"><%= t.feature.feature2_btn %></a>
                  </div>
                  <div class="feature-features">
                      <img class="feature-img" src="../../static/assets/feature3.webp" alt="Productivity quiz and recommendations">
                      <h3 class="feature-heading"><%= t.feature.feature3_title %></h3>
                      <p class="feature-text"><%= t.feature.feature3_desc %></p>
                      <a href="#" class="feature-btn feature-btn" aria-label="Take productivity quiz"><%= t.feature.feature3_btn %></a>
                  </div>
              </div>
              <div class="feature-even-column-right">
                  <div class="feature-features">
                      <img class="feature-img" src="../../static/assets/feature4.webp" alt="Task templates gallery">
                      <h3 class="feature-heading"><%= t.feature.feature4_title %></h3>
                      <p class="feature-text"><%= t.feature.feature4_desc %></p>
                      <a href="#" class="feature-btn feature-btn" aria-label="Start with templates"><%= t.feature.feature4_btn %></a>
                  </div>
                  <div class="feature-features">
                      <img class="feature-img" src="../../static/assets/feature5.webp" alt="Integration with other tools and calendar">
                      <h3 class="feature-heading"><%= t.feature.feature5_title %></h3>
                      <p class="feature-text"><%= t.feature.feature5_desc %></p>
                      <a href="#" class="feature-btn feature-btn" aria-label="Install integrations"><%= t.feature.feature5_btn %></a>
                  </div>
              </div>
          </div>
      </div>
  </section>
  </body>
</html>
